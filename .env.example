# ============================================================
# AI Job Assistant - Environment Variables Template
# ============================================================
# HOW TO USE:
# 1. Make a copy of this file
# 2. Rename the copy to exactly:  .env
# 3. Fill in your real API keys below
# 4. NEVER upload .env to GitHub — it has secret keys!
# ============================================================

# --- Google Gemini AI ---
# Get your free key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# --- RapidAPI JSearch (Real Job Listings) ---
# Get your free key from: https://rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch
# Free tier gives 200 requests/month — enough for demo and testing
RAPIDAPI_KEY=your_rapidapi_key_here

# --- App Behaviour Settings ---
# Change to "true" if you have a RapidAPI key and want real jobs
# Keep as "false" to use mock job data (works without any API key)
USE_REAL_JOBS_API=false